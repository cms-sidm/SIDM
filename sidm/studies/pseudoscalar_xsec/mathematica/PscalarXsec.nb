Cell[CellGroupData[{

Cell["gluon fusion process (top and bottom quark loops)", "Subsubsection",
 CellChangeTimes->{{3.743449012366281*^9, 3.743449016934559*^9}, {
  3.743644050003216*^9, 3.743644064024622*^9}, {3.743877092118585*^9, 
  3.743877094259355*^9}, {3.747602756857896*^9, 3.747602761944846*^9}, {
  3.7726179236715*^9, 3.7726179447921886`*^9}, {3.772680723484243*^9, 
  3.772680729389147*^9}},ExpressionUUID->"be4d43a7-7b1c-409d-b623-\
a39944247ee7"],

Cell[TextData[{
 "The effective coupling ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{
     SubscriptBox["G", "\[Mu]\[Nu]"], 
     SuperscriptBox["G", "\[Mu]\[Nu]"], "h"}], "\[CapitalLambda]"], 
   TraditionalForm]],ExpressionUUID->"ceafeed7-e3e6-4639-afb4-d1f8de996d1e"]
}], "Text",
 CellChangeTimes->{{3.743449053100655*^9, 
  3.743449071175453*^9}},ExpressionUUID->"16cdd31a-503b-4ef0-b49a-\
2049d82e40a0"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"floop", "[", "tau_", "]"}], ":=", 
   RowBox[{"Piecewise", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"ArcSin", "[", 
          RowBox[{"Sqrt", "[", "tau", "]"}], "]"}], "^", "2"}], ",", 
        RowBox[{"tau", "\[LessEqual]", "1"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"-", 
          FractionBox["1", "4"]}], 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Log", "[", 
             FractionBox[
              RowBox[{"1", "+", 
               RowBox[{"Sqrt", "[", 
                RowBox[{"1", "-", 
                 RowBox[{"1", "/", "tau"}]}], "]"}]}], 
              RowBox[{"1", "-", 
               RowBox[{"Sqrt", "[", 
                RowBox[{"1", "-", 
                 RowBox[{"1", "/", "tau"}]}], "]"}]}]], "]"}], "-", 
            RowBox[{"I", "*", "Pi"}]}], ")"}], "^", "2"}]}], ",", 
        RowBox[{"tau", ">", "1"}]}], "}"}]}], "}"}], "]"}]}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"sum", " ", "over", " ", 
    RowBox[{"floop", "[", "]"}], " ", "of", " ", "quarks"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"A12A", "[", "tau_", "]"}], ":=", 
  RowBox[{
   FractionBox["2", "tau"], 
   RowBox[{"floop", "[", "tau", "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"CrossDMSimpGfusionMSTW", "[", 
   RowBox[{
   "mDM_", ",", "mA_", ",", "tan\[Beta]_", ",", "\[Alpha]D_", ",", "yq_", ",",
     "y\[Chi]_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "f", ",", "\[CapitalGamma]A", ",", "\[CapitalGamma]BS", ",", "Meigen", ",",
       "mM2", ",", "mB2", ",", "\[CapitalGamma]MmM", ",", 
      "\[CapitalGamma]BmB", ",", "\[CapitalLambda]InverseSquare", ",", 
      "\[Sigma]gfusionA"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"\[CapitalGamma]A", "=", 
      RowBox[{"Abs", "[", 
       RowBox[{
        RowBox[{
         FractionBox["3", 
          RowBox[{"8", " ", "Pi"}]], " ", 
         SuperscriptBox[
          RowBox[{"(", 
           FractionBox[
            RowBox[{"yb", " ", "yq"}], 
            RowBox[{"Sqrt", "[", "2", "]"}]], ")"}], "2"], " ", 
         SuperscriptBox["tan\[Beta]", "2"], " ", "mA", " ", 
         SqrtBox[
          RowBox[{"1", "-", 
           RowBox[{"4", 
            FractionBox[
             SuperscriptBox["mb", "2"], 
             SuperscriptBox["mA", "2"]]}]}]]}], "+", 
        RowBox[{
         FractionBox["3", 
          RowBox[{"8", " ", "Pi"}]], " ", 
         SuperscriptBox[
          RowBox[{"(", 
           FractionBox[
            RowBox[{"yt", " ", "yq"}], 
            RowBox[{"Sqrt", "[", "2", "]"}]], ")"}], "2"], " ", 
         FractionBox["1", 
          SuperscriptBox["tan\[Beta]", "2"]], " ", "mA", " ", 
         SqrtBox[
          RowBox[{"1", "-", 
           RowBox[{"4", 
            FractionBox[
             SuperscriptBox["mt", "2"], 
             SuperscriptBox["mA", "2"]]}]}]], " ", 
         RowBox[{"HeavisideTheta", "[", 
          RowBox[{"mA", "-", 
           RowBox[{"2", "mt"}]}], "]"}]}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"\[CapitalGamma]BS", "=", 
      RowBox[{
       FractionBox[
        SuperscriptBox["\[Alpha]D", "5"], "4"], 
       RowBox[{"(", 
        RowBox[{"2", "mDM"}], ")"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"f", "=", 
      SqrtBox[
       FractionBox[
        RowBox[{
         SuperscriptBox["\[Alpha]D", "3"], " ", 
         SuperscriptBox["mDM", "2"]}], 
        RowBox[{"8", "Pi"}]]]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Meigen", "=", 
      RowBox[{"Eigenvalues", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            SuperscriptBox["mA", "2"], "-", 
            RowBox[{"\[ImaginaryI]", " ", "mA", "*", "\[CapitalGamma]A"}]}], ",", 
           RowBox[{"-", 
            SuperscriptBox["f", "2"]}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", 
            SuperscriptBox["f", "2"]}], ",", 
           RowBox[{
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"2", "mDM"}], ")"}], "2"], "-", 
            RowBox[{"\[ImaginaryI]", 
             RowBox[{"(", 
              RowBox[{"2", "mDM"}], ")"}], "*", "\[CapitalGamma]BS"}]}]}], 
          "}"}]}], "}"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "mM2", ",", "mB2", ",", "\[CapitalGamma]MmM", ",", 
        "\[CapitalGamma]BmB"}], "}"}], "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Re", "[", 
         RowBox[{"Meigen", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "]"}], ",", 
        RowBox[{"Re", "[", 
         RowBox[{"Meigen", "[", 
          RowBox[{"[", "2", "]"}], "]"}], "]"}], ",", 
        RowBox[{"Im", "[", 
         RowBox[{"Meigen", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "]"}], ",", 
        RowBox[{"Im", "[", 
         RowBox[{"Meigen", "[", 
          RowBox[{"[", "2", "]"}], "]"}], "]"}]}], "}"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"\[CapitalLambda]InverseSquare", "=", 
      RowBox[{
       FractionBox[
        RowBox[{
         SuperscriptBox["alphaS", "2"], 
         SuperscriptBox["yq", "2"]}], 
        RowBox[{
         SuperscriptBox["16", "2"], " ", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Sqrt", "[", "2", "]"}], " ", "vev"}], ")"}], "2"], " ", 
         SuperscriptBox["Pi", "2"]}]], 
       SuperscriptBox[
        RowBox[{"Abs", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"A12A", "[", 
            FractionBox["mB2", 
             RowBox[{"4", 
              RowBox[{"mt", "^", "2"}]}]], "]"}], "*", 
           FractionBox["1", "tan\[Beta]"]}], "+", 
          RowBox[{
           RowBox[{"A12A", "[", 
            FractionBox["mB2", 
             RowBox[{"4", 
              RowBox[{"mb", "^", "2"}]}]], "]"}], "*", "tan\[Beta]"}]}], 
         "]"}], "2"]}]}], ";", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"top", " ", "&"}], "  ", "bottom", " ", "loop"}], "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{"\[Sigma]gfusionA", "=", 
      RowBox[{
       RowBox[{
        FractionBox[
         RowBox[{
          RowBox[{"Zeta", "[", "3", "]"}], "Pi"}], 
         RowBox[{"256", " "}]], 
        FractionBox[
         RowBox[{
          SuperscriptBox["\[Alpha]D", "3"], " ", 
          SuperscriptBox["y\[Chi]", "2"], " ", 
          SuperscriptBox["mB2", "3"]}], 
         RowBox[{
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{"mB2", "-", "mM2"}], ")"}], "2"], "+", 
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{"\[CapitalGamma]MmM", "-", "\[CapitalGamma]BmB"}], ")"}], 
           "2"]}]], " ", "\[CapitalLambda]InverseSquare", " ", 
        RowBox[{"(", 
         RowBox[{
          FractionBox["1", 
           SuperscriptBox["sS", "2"]], 
          RowBox[{"NIntegrate", "[", 
           RowBox[{
            FractionBox[
             RowBox[{
              RowBox[{"xf", "[", 
               RowBox[{"0", ",", "x", ",", 
                SqrtBox["mB2"], ",", "0"}], "]"}], 
              RowBox[{"(", 
               RowBox[{"xf", "[", 
                RowBox[{"0", ",", 
                 FractionBox["mB2", 
                  RowBox[{"x", 
                   SuperscriptBox[
                    RowBox[{"(", "sS", ")"}], "2"]}]], ",", 
                 SqrtBox["mB2"], ",", "0"}], "]"}], ")"}]}], 
             RowBox[{"x", " ", "*", 
              FractionBox["mB2", 
               SuperscriptBox[
                RowBox[{"(", "sS", ")"}], "2"]]}]], ",", 
            RowBox[{"{", 
             RowBox[{"x", ",", 
              FractionBox["mB2", 
               SuperscriptBox[
                RowBox[{"(", "sS", ")"}], "2"]], ",", "1."}], "}"}], ",", 
            RowBox[{"MaxRecursion", "\[Rule]", "100"}]}], "]"}]}], ")"}], "*", 
        RowBox[{
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"2", "*", 
            SuperscriptBox["10", 
             RowBox[{"-", "14"}]]}], ")"}], "2"], "/", 
         RowBox[{"(", 
          SuperscriptBox["10", 
           RowBox[{"-", "39"}]], ")"}]}]}], "//", "Quiet"}]}]}]}], 
   "\[IndentingNewLine]", "]"}], 
  RowBox[{"(*", " ", 
   RowBox[{"CrossDMSimpGfusionMSTW", " ", "is", " ", "in", " ", "fb"}], " ", 
   "*)"}]}]}], "Input",
 CellChangeTimes->{{3.743448720895678*^9, 3.743448721036216*^9}, {
   3.743448756706112*^9, 3.743448761052544*^9}, {3.743449766896246*^9, 
   3.743449767784237*^9}, {3.743454381144649*^9, 3.7434543952454977`*^9}, 
   3.743454452090907*^9, {3.743454532819045*^9, 3.743454542277646*^9}, {
   3.743454614071027*^9, 3.7434546409473343`*^9}, {3.7434546849733887`*^9, 
   3.743454686907034*^9}, {3.7434561418691263`*^9, 3.743456144474427*^9}, {
   3.743461993080619*^9, 3.743461994710065*^9}, {3.7434620340125637`*^9, 
   3.743462072039839*^9}, {3.7434731165728397`*^9, 3.743473118556913*^9}, {
   3.7434745592713413`*^9, 3.743474585719898*^9}, 3.743474639549677*^9, {
   3.743639256431468*^9, 3.743639273088295*^9}, {3.7436476185838413`*^9, 
   3.743647623020564*^9}, {3.743647670558609*^9, 3.743647674699148*^9}, {
   3.7437149458690357`*^9, 3.743714971791135*^9}, {3.743715014027013*^9, 
   3.743715088572757*^9}, {3.7437151396160917`*^9, 3.743715149615645*^9}, {
