   3.745279625490838*^9, 3.7452796388497267`*^9}, 3.745637158525875*^9, {
   3.7456970608475237`*^9, 3.745697061572051*^9}, {3.745697402537109*^9, 
   3.745697411354858*^9}, {3.745710755544505*^9, 3.745710757844338*^9}, 
   3.74571080049401*^9, {3.745713887767633*^9, 3.7457138894203863`*^9}, {
   3.745716332228204*^9, 3.745716369045261*^9}, {3.745716449415495*^9, 
