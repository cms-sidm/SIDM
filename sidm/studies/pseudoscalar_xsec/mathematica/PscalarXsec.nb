Cell[CellGroupData[{

Cell["q qbar fusion process", "Subsubsection",
 CellChangeTimes->{{3.743448986189695*^9, 
  3.743449007894733*^9}},ExpressionUUID->"ffaa65e4-f698-421d-949c-\
a7c7309bee30"],

Cell[BoxData[
 RowBox[{
  RowBox[{"CrossDMSimpQfusionMSTW", "[", 
   RowBox[{
   "mDM_", ",", "mA_", ",", "tan\[Beta]_", ",", "\[Alpha]D_", ",", "yq_", ",",
     "y\[Chi]_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "ykwq", ",", "f", ",", "\[CapitalGamma]A", ",", "\[CapitalGamma]BS", ",",
       "Meigen", ",", "mM2", ",", "mB2", ",", "\[CapitalGamma]MmM", ",", 
      "\[CapitalGamma]BmB", ",", "\[Sigma]qfusionA"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"ykwq", "=", 
      RowBox[{"{", 
       RowBox[{
        FractionBox[
         RowBox[{"48", "*", 
          SuperscriptBox["10", 
           RowBox[{"-", "4"}]], " ", "tan\[Beta]"}], "vev"], ",", 
        FractionBox[
         RowBox[{"23", "*", 
          SuperscriptBox["10", 
           RowBox[{"-", "4"}]]}], 
