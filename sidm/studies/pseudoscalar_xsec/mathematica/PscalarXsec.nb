  InformationData[<|
   "ObjectType" -> "Symbol", "Usage" -> 
    "The function ReadPDFGrid[prefix,ih] reads the PDF grid corresponding to \
eigenvector set ih, where ih=0 is the central set, into memory from the \
location specified by prefix.", "Documentation" -> None, "OwnValues" -> None, 
    "UpValues" -> None, "DownValues" -> 
    Information`InformationValueForm[
     DownValues, mstwpdf`ReadPDFGrid, {mstwpdf`ReadPDFGrid[
         Pattern[mstwpdf`Private`prefix, 
          Blank[String]], 
         Pattern[mstwpdf`Private`ih, 
          Blank[Integer]]] :> 
       Module[{mstwpdf`Private`pdffile, mstwpdf`Private`pdfdat, 
          mstwpdf`Private`mc2, mstwpdf`Private`mb2}, 
         mstwpdf`Private`pdffile = 
          mstwpdf`Private`prefix <> "." <> 
           If[mstwpdf`Private`ih < 10, "0", ""] <> 
           ToString[mstwpdf`Private`ih] <> ".dat"; 
         mstwpdf`Private`pdfdat = OpenRead[mstwpdf`Private`pdffile]; 
         ReadList[mstwpdf`Private`pdfdat, String, 2]; 
         ReadList[mstwpdf`Private`pdfdat, Word, 3]; 
         mstwpdf`distance = Read[mstwpdf`Private`pdfdat, Number]; 
         mstwpdf`tolerance = Read[mstwpdf`Private`pdfdat, Number]; 
         ReadList[mstwpdf`Private`pdfdat, Word, 3]; 
         mstwpdf`mCharm = Read[mstwpdf`Private`pdfdat, Number]; 
         ReadList[mstwpdf`Private`pdfdat, Word, 3]; 
         mstwpdf`mBottom = Read[mstwpdf`Private`pdfdat, Number]; 
         ReadList[mstwpdf`Private`pdfdat, Word, 3]; 
         mstwpdf`alphaSQ0 = Read[mstwpdf`Private`pdfdat, Number]; 
         ReadList[mstwpdf`Private`pdfdat, Word, 3]; 
         mstwpdf`alphaSMZ = Read[mstwpdf`Private`pdfdat, Number]; 
         ReadList[mstwpdf`Private`pdfdat, Word, 3]; 
         mstwpdf`alphaSorder = Read[mstwpdf`Private`pdfdat, Number]; 
         mstwpdf`Private`comma = Read[mstwpdf`Private`pdfdat, Character]; 
         mstwpdf`alphaSnfmax = Read[mstwpdf`Private`pdfdat, Number]; 
         ReadList[mstwpdf`Private`pdfdat, Word, 3]; 
         mstwpdf`Private`nExtraFlavours = 
          Read[mstwpdf`Private`pdfdat, Number]; While[Part[
             StringLength[
              ReadList[mstwpdf`Private`pdfdat, String, 1]], 1] == 0, Null]; 
         mstwpdf`Private`mc2 = mstwpdf`mCharm^2; 
         mstwpdf`Private`mb2 = mstwpdf`mBottom^2; 
         mstwpdf`Private`qq = mstwpdf`Private`qqorig; Which[
           Or[
           mstwpdf`Private`mc2 <= Part[mstwpdf`Private`qq, 1], 
            mstwpdf`Private`mc2 + mstwpdf`Private`eps >= 
            Part[mstwpdf`Private`qq, 8]], {
           Print["Error in ReadPDFGrid: invalid mCharm = ", mstwpdf`mCharm]; 
            Abort[]; Null}, mstwpdf`Private`mc2 < 
           Part[mstwpdf`Private`qq, 2], {
           mstwpdf`Private`nqc0 = 2; 
            Part[mstwpdf`Private`qq, 4] = Part[mstwpdf`Private`qq, 2]; 
            Part[mstwpdf`Private`qq, 5] = Part[mstwpdf`Private`qq, 3]; Null}, 
           mstwpdf`Private`mc2 < Part[mstwpdf`Private`qq, 3], {
           mstwpdf`Private`nqc0 = 3; 
            Part[mstwpdf`Private`qq, 5] = Part[mstwpdf`Private`qq, 3]; Null}, 
           mstwpdf`Private`mc2 < Part[mstwpdf`Private`qq, 6], {
           mstwpdf`Private`nqc0 = 4; Null}, mstwpdf`Private`mc2 < 
           Part[mstwpdf`Private`qq, 7], {
           mstwpdf`Private`nqc0 = 5; 
            Part[mstwpdf`Private`qq, 4] = Part[mstwpdf`Private`qq, 6]; Null}, 
           True, {mstwpdf`Private`nqc0 = 6; 
            Part[mstwpdf`Private`qq, 4] = Part[mstwpdf`Private`qq, 6]; 
            Part[mstwpdf`Private`qq, 5] = Part[mstwpdf`Private`qq, 7]; Null}]; 
         Which[
           Or[
           mstwpdf`Private`mb2 <= Part[mstwpdf`Private`qq, 12], 
            mstwpdf`Private`mb2 + mstwpdf`Private`eps >= 
            Part[mstwpdf`Private`qq, 17]], {
           Print["Error in ReadPDFGrid: invalid mBottom = ", mstwpdf`mBottom]; 
            Abort[]; Null}, mstwpdf`Private`mb2 < 
           Part[mstwpdf`Private`qq, 13], {
           mstwpdf`Private`nqb0 = 13; 
            Part[mstwpdf`Private`qq, 15] = Part[mstwpdf`Private`qq, 13]; 
            Null}, mstwpdf`Private`mb2 < Part[mstwpdf`Private`qq, 16], {
           mstwpdf`Private`nqb0 = 14; Null}, True, {
           mstwpdf`Private`nqb0 = 15; 
            Part[mstwpdf`Private`qq, 14] = Part[mstwpdf`Private`qq, 16]; 
            Null}]; Part[mstwpdf`Private`qq, mstwpdf`Private`nqc0] = 
          mstwpdf`Private`mc2; 
         Part[mstwpdf`Private`qq, mstwpdf`Private`nqc0 + 1] = 
          mstwpdf`Private`mc2 + mstwpdf`Private`eps; 
         Part[mstwpdf`Private`qq, mstwpdf`Private`nqb0] = mstwpdf`Private`mb2; 
         Part[mstwpdf`Private`qq, mstwpdf`Private`nqb0 + 1] = 
          mstwpdf`Private`mb2 + mstwpdf`Private`eps; If[
           Or[
           mstwpdf`Private`nExtraFlavours < 0, mstwpdf`Private`nExtraFlavours > 
            1], {Print[
             "Error in ReadPDFGrid: invalid nExtraFlavours = ", 
              mstwpdf`Private`nExtraFlavours]; Abort[]; Null}]; 
         mstwpdf`Private`xxlog = Log[10, mstwpdf`Private`xx]; 
         mstwpdf`Private`qqlog = Log[10, mstwpdf`Private`qq]; 
         mstwpdf`Private`grid = 
          Table[0., {mstwpdf`Private`ip, 1, mstwpdf`Private`np}, {
            mstwpdf`Private`ixq, 1, mstwpdf`Private`nx mstwpdf`Private`nq}]; 
         Do[Part[mstwpdf`Private`grid, 
             mstwpdf`Private`ip, (mstwpdf`Private`ix - 1) mstwpdf`Private`nq + 
             mstwpdf`Private`iq] = {{
              Part[mstwpdf`Private`xxlog, mstwpdf`Private`ix], 
              Part[mstwpdf`Private`qqlog, mstwpdf`Private`iq]}, 
             If[
              Or[mstwpdf`Private`ix == mstwpdf`Private`nx, 
               And[mstwpdf`alphaSorder < 2, 
                Or[mstwpdf`Private`ip == 10, mstwpdf`Private`ip == 11]], 
               And[
               mstwpdf`Private`nExtraFlavours < 1, mstwpdf`Private`ip == 12]],
               0., 
              Read[mstwpdf`Private`pdfdat, Number]]}, {
           mstwpdf`Private`ix, 1, mstwpdf`Private`nx}, {
           mstwpdf`Private`iq, 1, mstwpdf`Private`nq}, {
           mstwpdf`Private`ip, 1, mstwpdf`Private`np}]; 
         If[Read[mstwpdf`Private`pdfdat] == EndOfFile, Null, Null, {
           Print["Error in ReadPDFGrid: not at end of ", 
              mstwpdf`Private`pdffile]; Abort[]; Null}]; 
         Close[mstwpdf`Private`pdfdat]; 
         mstwpdf`Private`ff = 
          Table[0., {mstwpdf`Private`ip, 1, mstwpdf`Private`np}, {
            mstwpdf`Private`ix, 1, mstwpdf`Private`nx}, {
            mstwpdf`Private`iq, 1, mstwpdf`Private`nq}]; 
         Do[Part[mstwpdf`Private`ff, mstwpdf`Private`ip, mstwpdf`Private`ix, 
             mstwpdf`Private`iq] = 
           Part[mstwpdf`Private`grid, 
             mstwpdf`Private`ip, (mstwpdf`Private`ix - 1) mstwpdf`Private`nq + 
             mstwpdf`Private`iq, 2], {
           mstwpdf`Private`ip, 1, mstwpdf`Private`np}, {
           mstwpdf`Private`ix, 1, mstwpdf`Private`nx}, {
           mstwpdf`Private`iq, 1, mstwpdf`Private`nq}]; Do[
           mstwpdf`Private`InitialisePDF[
           mstwpdf`Private`p, mstwpdf`Private`ih], {
           mstwpdf`Private`p, 1, mstwpdf`Private`np}]; 
         Print["PDF grid read from ", mstwpdf`Private`pdffile]; Null]}], 
    "SubValues" -> None, "DefaultValues" -> None, "NValues" -> None, 
    "FormatValues" -> None, "Options" -> None, "Attributes" -> {}, "FullName" -> 
    "mstwpdf`ReadPDFGrid"|>, False]]], "Output",
 CellChangeTimes->{3.9591524666831617`*^9, 3.961142856643485*^9, 
