     RowBox[{"Log10", "[", "functionValuesTable", "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"2.", " ", 
     RowBox[{"(", 
      RowBox[{"NEW", " ", "STEP"}], ")"}], " ", "Clean", " ", "the", " ", 
     "data", " ", "by", " ", "replacing", " ", "errors", " ", "with", " ", 
     "an", " ", "invisible", " ", "value"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"This", " ", "is", " ", "the", " ", "crucial", " ", 
      RowBox[{"fix", ".", "It"}], " ", "replaces", " ", "any", " ", "non"}], "-", 
     RowBox[{"numeric", " ", "results"}]}], "*)"}], "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"where", " ", "NIntegrate", " ", "failed"}], ")"}], " ", "with",
      " ", 
     RowBox[{"Transparent", "."}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"cleanedLogData", "=", 
     RowBox[{"Replace", "[", 
      RowBox[{"logXsecData", ",", 
       RowBox[{
        RowBox[{"_", "?", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"!", 
            RowBox[{"NumericQ", "[", "#", "]"}]}], "&"}], ")"}]}], "->", 
        "Transparent"}], ",", 
       RowBox[{"{", "2", "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "3.", " ", "Define", " ", "the", " ", "range", " ", "and", " ", "ticks", " ",
      "for", " ", "the", " ", "color", " ", "bar"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"min", ",", "max"}], "}"}], "=", 
     RowBox[{"MinMax", "[", 
      RowBox[{"Select", "[", 
       RowBox[{
        RowBox[{"Flatten", "[", "cleanedLogData", "]"}], ",", "NumberQ"}], 
       "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"tickValues", "=", 
     RowBox[{"10", "^", 
      RowBox[{"FindDivisions", "[", 
       RowBox[{
        RowBox[{"Log10", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"10", "^", "min"}], ",", 
           RowBox[{"10", "^", "max"}]}], "}"}], "]"}], ",", "5"}], "]"}]}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"customTicks", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Log10", "[", "val", "]"}], ",", 
         RowBox[{"NumberForm", "[", 
          RowBox[{"val", ",", 
           RowBox[{"{", 
            RowBox[{"3", ",", "0"}], "}"}]}], "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"val", ",", "tickValues"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "4.", " ", "Define", " ", "the", " ", "ticks", " ", "for", " ", "the", " ",
      "plot", " ", "frame"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"yTicks", "=", 
     RowBox[{"FindDivisions", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"200", ",", "1000"}], "}"}], ",", "10"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"xTicks", "=", 
     RowBox[{"FindDivisions", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"10", ",", "500"}], "}"}], ",", "10"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "5.", " ", "Generate", " ", "the", " ", "plot", " ", "using", " ", 
      "standard"}], ",", 
     RowBox[{"simple", " ", "ArrayPlot"}]}], "*)"}], "\n", 
   RowBox[{"(*", 
    RowBox[{"This", " ", "code", " ", "now", " ", "works", " ", 
     RowBox[{"because", "'"}], 
     RowBox[{"cleanedLogData", "'"}], " ", "is", " ", "free", " ", "of", " ", 
     RowBox[{"errors", "."}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"ArrayPlot", "[", 
    RowBox[{"cleanedLogData", ",", 
     RowBox[{"DataRange", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"10", ",", "500"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"200", ",", "1000"}], "}"}]}], "}"}]}], ",", 
     RowBox[{"ColorFunction", "->", "\"\<Rainbow\>\""}], ",", 
     RowBox[{"PlotLegends", "->", 
      RowBox[{"BarLegend", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"Automatic", ",", 
          RowBox[{"{", 
           RowBox[{"min", ",", "max"}], "}"}]}], "}"}], ",", "customTicks"}], 
       "]"}]}], ",", 
     RowBox[{"Frame", "->", "True"}], ",", 
     RowBox[{"FrameTicks", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"yTicks", ",", "None"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"xTicks", ",", "None"}], "}"}]}], "}"}]}], ",", 
     RowBox[{"FrameLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<mXX [GeV]\>\"", ",", "\"\<mA [GeV]\>\""}], "}"}]}], ",", 
     RowBox[{
     "PlotLabel", "->", "\"\<Production Cross Section of P scalar (pb)\>\""}],
      ",", 
     RowBox[{"AspectRatio", "->", "1"}], ",", 
     RowBox[{"BaseStyle", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"FontFamily", "->", "\"\<Helvetica\>\""}], ",", 
        RowBox[{"FontSize", "->", "12"}]}], "}"}]}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{
  3.96157159250809*^9, {3.961572525544866*^9, 3.961572543009048*^9}},
