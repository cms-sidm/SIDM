# Minimal LPC interactive condor_config for use from outside the coffea-dask
# apptainer (e.g. from a notebook running in sidm_venv). Mirrors
# /etc/condor/config.d/01_cmslpc_interactive but omits the
# `include : /usr/local/bin/cmslpc-local-conf.py |` directive, which emits a
# LOCAL_CONFIG_FILE pointing at a per-user file under /storage/local/data1
# that does not always exist on cmslpc-el9 nodes. The CoffeaTeam apptainer
# bootstrap.sh works around the same issue by bind-mounting a wrapper that
# strips LOCAL_CONFIG_FILE lines.

FERMIHTC_REMOTE_POOL = cmst1mgr2.fnal.gov, cmst1mgr3.fnal.gov
COLLECTOR_HOST = $(FERMIHTC_REMOTE_POOL)
CONDOR_HOST = $(FERMIHTC_REMOTE_POOL)
TOOL_TIMEOUT_MULTIPLIER = 5
CONDOR_Q_DASH_BATCH_IS_DEFAULT = FALSE
JOB_DEFAULT_REQUESTMEMORY = 2048

SEC_DEFAULT_AUTHENTICATION_METHODS = FS_REMOTE
SEC_CLIENT_AUTHENTICATION_METHODS = FS_REMOTE
FS_REMOTE_DIR = /uscmst1b_scratch/lpc1/htcondor/

FERMIHTC_JOB_SOURCE = "$(HOSTNAME)"
SUBMIT_ATTRS = $(SUBMIT_ATTRS) FERMIHTC_JOB_SOURCE
